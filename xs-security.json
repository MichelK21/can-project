{
  "xsappname": "can-xsapp",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://can-approuter.cfapps.us10-001.hana.ondemand.com/login/callback"
    ]
  },
  "scopes": [{ "name": "$XSAPPNAME.user", "description": "User scope" }],
  "role-templates": [
    {
      "name": "User",
      "description": "User role",
      "scope-references": ["$XSAPPNAME.user"]
    }
  ]
}
